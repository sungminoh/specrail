{
  "name": "specrail-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "specrail monorepo — plugin + core + dashboard",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r --workspace-concurrency=1 test",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^20.10.0",
    "typescript": "^5.6.0",
    "vitest": "^1.6.0"
  }
}
