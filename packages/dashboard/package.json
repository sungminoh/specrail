{
  "name": "@specrail/dashboard",
  "version": "0.1.0-alpha.1",
  "description": "Local web app for viewing, relating, and AI-reviewing specrail 13-phase markdown specs",
  "type": "module",
  "private": false,
  "bin": {
    "specrail-dashboard": "./dist/bin/specrail-dashboard.js"
  },
  "files": [
    "dist",
    "README.md",
    "DESIGN.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "pnpm build:server && pnpm build:web",
    "build:server": "node build/esbuild.mjs",
    "build:web": "vite build --config web/vite.config.ts",
    "dev": "concurrently -k -n SRV,WEB \"pnpm dev:server\" \"pnpm dev:web\"",
    "dev:server": "tsx watch server/main.ts",
    "dev:web": "vite --config web/vite.config.ts",
    "start": "node dist/bin/specrail-dashboard.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.3.0",
    "@codemirror/lang-yaml": "^6.1.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.4.0",
    "@codemirror/view": "^6.34.0",
    "@hono/node-server": "^2.0.2",
    "@hookform/resolvers": "^3.9.0",
    "@specrail/core": "workspace:*",
    "@tanstack/react-query": "^5.59.0",
    "@xyflow/react": "^12.3.0",
    "chokidar": "^4.0.0",
    "elkjs": "^0.9.3",
    "env-paths": "^3.0.0",
    "execa": "^9.5.0",
    "fuse.js": "^7.0.0",
    "gray-matter": "^4.0.3",
    "hono": "^4.6.0",
    "open": "^10.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.53.0",
    "react-router-dom": "^7.0.0",
    "rehype-raw": "^7.0.0",
    "rehype-stringify": "^10.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.0",
    "tsx": "^4.19.0",
    "unified": "^11.0.4",
    "write-file-atomic": "^6.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/node": "^20.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/write-file-atomic": "^4.0.3",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "esbuild": "^0.24.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
