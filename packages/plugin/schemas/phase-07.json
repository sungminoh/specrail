{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specrail.dev/schemas/phase-07.json",
  "title": "Phase 7 frontmatter",
  "type": "object",
  "required": [
    "phase",
    "status"
  ],
  "properties": {
    "phase": {
      "const": 7
    },
    "status": {
      "type": "string",
      "enum": [
        "Empty",
        "Draft",
        "Approved"
      ]
    },
    "mode": {
      "type": "string",
      "enum": [
        "SCOPE_EXPANSION",
        "SELECTIVE_EXPANSION",
        "HOLD_SCOPE",
        "SCOPE_REDUCTION"
      ]
    },
    "refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^([RFS]\\d+(\\.\\d+){0,2}|ENT-[A-Za-z0-9_]+|INV-\\d+|NFR-[A-Z]+-\\d+|ARCH-\\d+|EXT-\\d+|OPS-\\d+|ADR-\\d+|RISK-\\d+|TC-\\d+|EDGE-\\d+|AC-R\\d+-\\d+|T\\d+\\.\\d+)$"
      }
    },
    "approvedAt": {
      "type": "string"
    },
    "wireframes": {
      "type": "array",
      "description": "Wireframe specs (W-* IDs, 1:1 with P-* from phase 6) — each entry describes layout zones, element specs, and 4 component states (Loading/Empty/Error/Success)",
      "items": { "type": "object" }
    }
  },
  "additionalProperties": true
}
