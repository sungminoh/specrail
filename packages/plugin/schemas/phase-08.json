{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specrail.dev/schemas/phase-08.json",
  "title": "Phase 8 frontmatter",
  "type": "object",
  "required": [
    "phase",
    "status"
  ],
  "properties": {
    "phase": {
      "const": 8
    },
    "status": {
      "type": "string",
      "enum": [
        "Empty",
        "Draft",
        "Approved"
      ]
    },
    "mode": {
      "type": "string",
      "enum": [
        "SCOPE_EXPANSION",
        "SELECTIVE_EXPANSION",
        "HOLD_SCOPE",
        "SCOPE_REDUCTION"
      ]
    },
    "refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^([RFS]\\d+(\\.\\d+){0,2}|ENT-[A-Za-z0-9_]+|INV-\\d+|NFR-[A-Z]+-\\d+|ARCH-\\d+|EXT-\\d+|OPS-\\d+|ADR-\\d+|RISK-\\d+|TC-\\d+|EDGE-\\d+|AC-R\\d+-\\d+|T\\d+\\.\\d+)$"
      }
    },
    "approvedAt": {
      "type": "string"
    },
    "components": {
      "type": "array",
      "description": "Abstract system components (ARCH-* IDs) — C4 L2 containers: services, datastores, clients. No concrete vendor names.",
      "items": { "type": "object" }
    },
    "decisions": {
      "type": "array",
      "description": "ADR-CAND-* deferred decisions identified during architecture design (resolved in phase 12)",
      "items": { "type": "object" }
    },
    "integrations": {
      "type": "array",
      "description": "External integrations (EXT-* IDs) — third-party systems, APIs, and services the system depends on",
      "items": { "type": "object" }
    }
  },
  "additionalProperties": true
}
