{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specrail.dev/schemas/phase-11.json",
  "title": "Phase 11 frontmatter",
  "type": "object",
  "required": [
    "phase",
    "status"
  ],
  "properties": {
    "phase": {
      "const": 11
    },
    "status": {
      "type": "string",
      "enum": [
        "Empty",
        "Draft",
        "Approved"
      ]
    },
    "mode": {
      "type": "string",
      "enum": [
        "SCOPE_EXPANSION",
        "SELECTIVE_EXPANSION",
        "HOLD_SCOPE",
        "SCOPE_REDUCTION"
      ]
    },
    "refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^([RFS]\\d+(\\.\\d+){0,2}|ENT-[A-Za-z0-9_]+|INV-\\d+|NFR-[A-Z]+-\\d+|ARCH-\\d+|EXT-\\d+|OPS-\\d+|ADR-\\d+|RISK-\\d+|TC-\\d+|EDGE-\\d+|AC-R\\d+-\\d+|T\\d+\\.\\d+)$"
      }
    },
    "approvedAt": {
      "type": "string"
    },
    "runbooks": {
      "type": "array",
      "description": "Operational runbooks (OPS-* IDs) — deploy strategy, DR/backup procedures, on-call playbooks. Abstract tool references only (concrete vendor = ADR-CAND).",
      "items": { "type": "object" }
    },
    "monitoring": {
      "type": "array",
      "description": "Observability specs — Logs / Metrics / Traces per ARCH component, with alert policies tied to PRD KPI / NFR",
      "items": { "type": "object" }
    }
  },
  "additionalProperties": true
}
