{
  "name": "@specrail/core",
  "version": "0.1.0",
  "description": "specrail core domain — frontmatter, patch, graph, checks (pure, no I/O)",
  "type": "module",
  "private": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" },
    "./frontmatter": { "import": "./dist/frontmatter/index.js", "types": "./dist/frontmatter/index.d.ts" },
    "./patch": { "import": "./dist/patch/index.js", "types": "./dist/patch/index.d.ts" },
    "./graph": { "import": "./dist/graph/index.js", "types": "./dist/graph/index.d.ts" },
    "./checks": { "import": "./dist/checks/index.js", "types": "./dist/checks/index.d.ts" },
    "./spec": { "import": "./dist/spec/index.js", "types": "./dist/spec/index.d.ts" }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.4",
    "unist-util-visit": "^5.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^1.6.0",
    "typescript": "^5.6.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
