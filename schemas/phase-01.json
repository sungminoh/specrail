{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plan-pipeline.dev/schemas/phase-01.json",
  "title": "Phase 1: PRD frontmatter",
  "type": "object",
  "required": [
    "phase",
    "status"
  ],
  "properties": {
    "phase": {
      "const": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "Empty",
        "Draft",
        "Approved"
      ]
    },
    "mode": {
      "type": "string",
      "enum": [
        "SCOPE_EXPANSION",
        "SELECTIVE_EXPANSION",
        "HOLD_SCOPE",
        "SCOPE_REDUCTION"
      ]
    },
    "refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^([RFS]\\d+(\\.\\d+){0,2}|ENT-[A-Za-z0-9_]+|INV-\\d+|NFR-[A-Z]+-\\d+|ARCH-\\d+|EXT-\\d+|OPS-\\d+|ADR-\\d+|RISK-\\d+|TC-\\d+|EDGE-\\d+|AC-R\\d+-\\d+|T\\d+\\.\\d+)$"
      }
    },
    "approvedAt": {
      "type": "string"
    },
    "kpi": {
      "type": "array",
      "description": "Key Performance Indicators — success metrics from PRD §4 (e.g. DAU, retention, conversion targets)",
      "items": { "type": "object" }
    },
    "personas": {
      "type": "array",
      "description": "Primary persona summaries — who the product is built for (PRD §3.1)",
      "items": { "type": "object" }
    },
    "risks": {
      "type": "array",
      "description": "Assumption risks identified during framing (PRD §7 Assumption table)",
      "items": { "type": "object" }
    }
  },
  "additionalProperties": true
}
