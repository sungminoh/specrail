{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plan-pipeline.dev/schemas/phase-03.json",
  "title": "Phase 3 frontmatter",
  "type": "object",
  "required": [
    "phase",
    "status"
  ],
  "properties": {
    "phase": {
      "const": 3
    },
    "status": {
      "type": "string",
      "enum": [
        "Empty",
        "Draft",
        "Approved"
      ]
    },
    "mode": {
      "type": "string",
      "enum": [
        "SCOPE_EXPANSION",
        "SELECTIVE_EXPANSION",
        "HOLD_SCOPE",
        "SCOPE_REDUCTION"
      ]
    },
    "refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^([RFS]\\d+(\\.\\d+){0,2}|ENT-[A-Za-z0-9_]+|INV-\\d+|NFR-[A-Z]+-\\d+|ARCH-\\d+|EXT-\\d+|OPS-\\d+|ADR-\\d+|RISK-\\d+|TC-\\d+|EDGE-\\d+|AC-R\\d+-\\d+|T\\d+\\.\\d+)$"
      }
    },
    "approvedAt": {
      "type": "string"
    },
    "features": {
      "type": "array",
      "description": "Feature list — R→F→S 3-tier breakdown; each entry is a Requirement with nested Features and Specifications",
      "items": { "type": "object" }
    },
    "requirements": {
      "type": "array",
      "description": "Flat Requirement list (R-IDs) for quick reference and cross-phase linking",
      "items": { "type": "object" }
    }
  },
  "additionalProperties": true
}
