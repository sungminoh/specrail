{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specrail.dev/schemas/change-proposal.json",
  "title": "DELTA change proposal frontmatter (Phase 4 ENT-Change)",
  "type": "object",
  "required": ["status", "date", "capability", "affectedPhases"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["proposed", "reviewed", "approved", "implementing", "applied", "archived"],
      "description": "SM-Change-Lifecycle status"
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "ISO date — change 생성 일자"
    },
    "capability": {
      "type": "string",
      "pattern": "^[a-z0-9가-힣]+(-[a-z0-9가-힣]+)*$",
      "description": "kebab-case capability slug (한국어 허용)"
    },
    "affectedPhases": {
      "type": "array",
      "items": { "type": "string", "pattern": "^\\d{2}$" },
      "minItems": 1,
      "description": "INV-6 — auto-extracted via graph downstream, ≥ 1"
    },
    "addedSpecIds": {
      "type": "array",
      "items": { "type": "string", "pattern": "^([RFS]\\d+(\\.\\d+){0,2}|ENT-[A-Za-z0-9_]+|INV-\\d+|NFR-[A-Z]+-\\d+|ARCH-\\d+|EXT-\\d+|OPS-\\d+|ADR-\\d+|RISK-\\d+|TC-\\d+|EDGE-\\d+)$" }
    },
    "modifiedSpecIds": {
      "type": "array",
      "items": { "type": "string" }
    },
    "removedSpecIds": {
      "type": "array",
      "items": { "type": "string" }
    },
    "appliedAt": {
      "type": "string",
      "description": "ISO datetime — implementation 완료 후 current/ 머지 시각"
    }
  },
  "additionalProperties": true
}
