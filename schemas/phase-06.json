{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plan-pipeline.dev/schemas/phase-06.json",
  "title": "Phase 6 frontmatter",
  "type": "object",
  "required": [
    "phase",
    "status"
  ],
  "properties": {
    "phase": {
      "const": 6
    },
    "status": {
      "type": "string",
      "enum": [
        "Empty",
        "Draft",
        "Approved"
      ]
    },
    "mode": {
      "type": "string",
      "enum": [
        "SCOPE_EXPANSION",
        "SELECTIVE_EXPANSION",
        "HOLD_SCOPE",
        "SCOPE_REDUCTION"
      ]
    },
    "refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^([RFS]\\d+(\\.\\d+){0,2}|ENT-[A-Za-z0-9_]+|INV-\\d+|NFR-[A-Z]+-\\d+|ARCH-\\d+|EXT-\\d+|OPS-\\d+|ADR-\\d+|RISK-\\d+|TC-\\d+|EDGE-\\d+|AC-R\\d+-\\d+|T\\d+\\.\\d+)$"
      }
    },
    "approvedAt": {
      "type": "string"
    },
    "screens": {
      "type": "array",
      "description": "Page/screen catalog (P-* IDs) — 1:1 mapping to Phase 5 page nodes, with hierarchy depth and navigation strategy",
      "items": { "type": "object" }
    },
    "navigationStrategy": {
      "type": "string",
      "description": "Primary navigation pattern: sidebar / tab / drawer / stack / etc. (justified by Persona environment)"
    }
  },
  "additionalProperties": true
}
