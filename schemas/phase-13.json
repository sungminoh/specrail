{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plan-pipeline.dev/schemas/phase-13.json",
  "title": "Phase 13: Implementation Plan frontmatter",
  "type": "object",
  "required": [
    "phase",
    "status"
  ],
  "properties": {
    "phase": {
      "const": 13
    },
    "status": {
      "type": "string",
      "enum": [
        "Empty",
        "Draft",
        "Approved"
      ]
    },
    "mode": {
      "type": "string",
      "enum": [
        "SCOPE_EXPANSION",
        "SELECTIVE_EXPANSION",
        "HOLD_SCOPE",
        "SCOPE_REDUCTION"
      ]
    },
    "refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^([RFS]\\d+(\\.\\d+){0,2}|ENT-[A-Za-z0-9_]+|INV-\\d+|NFR-[A-Z]+-\\d+|ARCH-\\d+|EXT-\\d+|OPS-\\d+|ADR-\\d+|RISK-\\d+|TC-\\d+|EDGE-\\d+|AC-R\\d+-\\d+|T\\d+\\.\\d+)$"
      }
    },
    "approvedAt": {
      "type": "string"
    },
    "tasks": {
      "type": "array",
      "description": "Atomic implementation tasks (T*.* IDs) — each has exact file path, complete code block, exact test command + expected output. No TBD/placeholders.",
      "items": { "type": "object" }
    },
    "acceptanceCriteria": {
      "type": "array",
      "description": "Phase-level acceptance criteria linking T-tasks to AC/TC IDs — used to verify MVP is shippable",
      "items": { "type": "object" }
    },
    "milestones": {
      "type": "array",
      "description": "Milestone groupings of tasks (M0 = MVP, M1 = polish, etc.) with dependency graph summary",
      "items": { "type": "object" }
    }
  },
  "additionalProperties": true
}
