{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plan-pipeline.dev/schemas/phase-12.json",
  "title": "Phase 12: ADR + Risks frontmatter",
  "type": "object",
  "required": [
    "phase",
    "status"
  ],
  "properties": {
    "phase": {
      "const": 12
    },
    "status": {
      "type": "string",
      "enum": [
        "Empty",
        "Draft",
        "Approved"
      ]
    },
    "mode": {
      "type": "string",
      "enum": [
        "SCOPE_EXPANSION",
        "SELECTIVE_EXPANSION",
        "HOLD_SCOPE",
        "SCOPE_REDUCTION"
      ]
    },
    "refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^([RFS]\\d+(\\.\\d+){0,2}|ENT-[A-Za-z0-9_]+|INV-\\d+|NFR-[A-Z]+-\\d+|ARCH-\\d+|EXT-\\d+|OPS-\\d+|ADR-\\d+|RISK-\\d+|TC-\\d+|EDGE-\\d+|AC-R\\d+-\\d+|T\\d+\\.\\d+)$"
      }
    },
    "approvedAt": {
      "type": "string"
    },
    "decisions": {
      "type": "array",
      "description": "Architecture Decision Records (ADR-* IDs) — each has one chosen option, rejected alternatives with reasons, and consequences. Resolves all ADR-CAND from previous phases.",
      "items": { "type": "object" }
    },
    "risks": {
      "type": "array",
      "description": "Risk register (RISK-* IDs) — Likelihood × Impact matrix with mitigation plans. Empty array if no identified risks.",
      "items": { "type": "object" }
    }
  },
  "additionalProperties": true
}
