{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plan-pipeline.dev/schemas/phase-02.json",
  "title": "Phase 2: Persona & Journey frontmatter",
  "type": "object",
  "required": [
    "phase",
    "status"
  ],
  "properties": {
    "phase": {
      "const": 2
    },
    "status": {
      "type": "string",
      "enum": [
        "Empty",
        "Draft",
        "Approved"
      ]
    },
    "mode": {
      "type": "string",
      "enum": [
        "SCOPE_EXPANSION",
        "SELECTIVE_EXPANSION",
        "HOLD_SCOPE",
        "SCOPE_REDUCTION"
      ]
    },
    "refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^([RFS]\\d+(\\.\\d+){0,2}|ENT-[A-Za-z0-9_]+|INV-\\d+|NFR-[A-Z]+-\\d+|ARCH-\\d+|EXT-\\d+|OPS-\\d+|ADR-\\d+|RISK-\\d+|TC-\\d+|EDGE-\\d+|AC-R\\d+-\\d+|T\\d+\\.\\d+)$"
      }
    },
    "approvedAt": {
      "type": "string"
    },
    "personas": {
      "type": "array",
      "description": "Persona cards — each entry is one deeply-specified persona with role, tools, goals, fears (the substance of phase 2)",
      "items": { "type": "object" }
    },
    "journeys": {
      "type": "array",
      "description": "Journey maps — one per core scenario, tracking emotion/thought/action per step",
      "items": { "type": "object" }
    },
    "painPriority": {
      "type": "array",
      "description": "Pain Priority table — P0/P1/P2 ranked pain points with persona/scenario references",
      "items": { "type": "object" }
    }
  },
  "additionalProperties": true
}
