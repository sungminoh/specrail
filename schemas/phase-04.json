{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specrail.dev/schemas/phase-04.json",
  "title": "Phase 4 frontmatter",
  "type": "object",
  "required": [
    "phase",
    "status"
  ],
  "properties": {
    "phase": {
      "const": 4
    },
    "status": {
      "type": "string",
      "enum": [
        "Empty",
        "Draft",
        "Approved"
      ]
    },
    "mode": {
      "type": "string",
      "enum": [
        "SCOPE_EXPANSION",
        "SELECTIVE_EXPANSION",
        "HOLD_SCOPE",
        "SCOPE_REDUCTION"
      ]
    },
    "refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^([RFS]\\d+(\\.\\d+){0,2}|ENT-[A-Za-z0-9_]+|INV-\\d+|NFR-[A-Z]+-\\d+|ARCH-\\d+|EXT-\\d+|OPS-\\d+|ADR-\\d+|RISK-\\d+|TC-\\d+|EDGE-\\d+|AC-R\\d+-\\d+|T\\d+\\.\\d+)$"
      }
    },
    "approvedAt": {
      "type": "string"
    },
    "entities": {
      "type": "array",
      "description": "Domain entities (ENT-* IDs) with attributes, state machines, and AC references",
      "items": { "type": "object" }
    },
    "relationships": {
      "type": "array",
      "description": "Entity relationships (1:1, 1:N, N:M) between domain entities",
      "items": { "type": "object" }
    },
    "invariants": {
      "type": "array",
      "description": "System invariants (INV-* IDs) — rules that must never be violated",
      "items": { "type": "object" }
    }
  },
  "additionalProperties": true
}
